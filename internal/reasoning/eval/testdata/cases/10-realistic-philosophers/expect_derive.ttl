@prefix ex: <http://example.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# subClassOf дј йҖ’пјҡStoicвҠ‘PhilosopherвҠ‘Person вҹ№ StoicвҠ‘Person
ex:Stoic rdfs:subClassOf ex:Person .

# inverseOfпјҡteaches вҶ’ taughtBy
ex:aristotle ex:taughtBy ex:plato .
ex:alexander ex:taughtBy ex:aristotle .

# зұ»еһӢз»§жүҝпјҡepictetus/marcus (Stoic) з»§жүҝ Philosopher е’Ң Person
ex:epictetus a ex:Philosopher .
ex:epictetus a ex:Person .
ex:marcus a ex:Philosopher .
ex:marcus a ex:Person .

# influences дј йҖ’й—ӯеҢ…
ex:socrates ex:influences ex:aristotle .
ex:plato ex:influences ex:alexander .
ex:socrates ex:influences ex:alexander .
