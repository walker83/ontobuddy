@prefix ex: <http://example.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

# === dependsOn дј йҖ’й—ӯеҢ…пјҲowl:TransitivePropertyпјү===
# cmd/myonto й—ҙжҺҘдҫқиө–еә•еұӮеҢ…пјҲз»Ҹ cliвҶ’store/reasoningвҶ’rdf/configвҶ’cryptoпјү
ex:pkg-cmd ex:dependsOn ex:pkg-store .
ex:pkg-cmd ex:dependsOn ex:pkg-reasoning .
ex:pkg-cmd ex:dependsOn ex:pkg-rdf .
ex:pkg-cmd ex:dependsOn ex:pkg-config .
ex:pkg-cmd ex:dependsOn ex:pkg-crypto .
# cli й—ҙжҺҘдҫқиө–
ex:pkg-cli ex:dependsOn ex:pkg-rdf .
ex:pkg-cli ex:dependsOn ex:pkg-config .
ex:pkg-cli ex:dependsOn ex:pkg-crypto .
# store й—ҙжҺҘдҫқиө–
ex:pkg-store ex:dependsOn ex:pkg-crypto .

# === зұ»еһӢз»§жүҝпјҲsubClassOf + rdf:typeпјү===
# жҜҸдёӘ Package е®һдҫӢиҮӘеҠЁжҲҗдёә CodeElement
ex:pkg-cmd rdf:type ex:CodeElement .
ex:pkg-cli rdf:type ex:CodeElement .
ex:pkg-store rdf:type ex:CodeElement .
ex:pkg-reasoning rdf:type ex:CodeElement .
ex:pkg-config rdf:type ex:CodeElement .
ex:pkg-rdf rdf:type ex:CodeElement .
ex:pkg-crypto rdf:type ex:CodeElement .
